@using Portfolio.Mockdata
@using Portfolio.Models
@inject IJSRuntime JS

<footer class="w-full py-12 px-6 md:px-12 border-t border-white/5 bg-[#0a0a0f]">
    <div class="max-w-screen-2xl mx-auto">
        <!-- First Row: 3 Columns (Centered) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-12 justify-items-center">
            <!-- Column 1: Brand Info -->
            <div class="space-y-4 text-center">
                <h3 class="footer-name-cyan font-headline text-lg font-bold uppercase tracking-tight">@info.Name.ToUpper()</h3>
                <p class="font-body text-sm text-on-surface-variant leading-relaxed max-w-xs">@info.HeadLine</p>
            </div>

            <!-- Column 2: Quick Links -->
            <div class="space-y-4 text-center">
                <h3 class="font-headline text-lg font-bold uppercase tracking-tight text-white">Quick Links</h3>
                <div class="flex flex-col gap-2 items-center">
                    <button @onclick="NavigateProjects" class="text-left font-body text-sm text-on-surface-variant hover:text-primary transition-colors w-fit">
                        Projects
                    </button>
                    <button @onclick="NavigateSkills" class="text-left font-body text-sm text-on-surface-variant hover:text-primary transition-colors w-fit">
                        Skills
                    </button>
                    <button @onclick="NavigateContact" class="text-left font-body text-sm text-on-surface-variant hover:text-primary transition-colors w-fit">
                        Contact
                    </button>
                </div>
            </div>

            <!-- Column 3: Connect -->
            <div class="space-y-4 text-center">
                <h3 class="font-headline text-lg font-bold uppercase tracking-tight text-white">Connect</h3>
                <div class="flex items-center justify-center gap-4">
                    @if (!string.IsNullOrEmpty(info.Social.Github))
                    {
                        <a href="@info.Social.Github" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-primary hover:bg-primary hover:text-background transition-all duration-300">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(info.Social.Linkedin))
                    {
                        <a href="@info.Social.Linkedin" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-primary hover:bg-primary hover:text-background transition-all duration-300">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(info.Email))
                    {
                        <a href="mailto:@info.Email" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-primary hover:bg-primary hover:text-background transition-all duration-300">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Divider -->
        <hr class="border-white/5" />

        <!-- Second Row: Copyright -->
        <div class="mt-8 flex justify-center">
            <p class="font-body text-xs text-on-surface-variant">
                © @DateTime.Now.Year @info.Name. All rights reserved.
            </p>
        </div>
    </div>
</footer>

@code {
    private readonly PersonalInfo info = PersonalInfoData.GetDeveloper();

    private async Task ScrollToSection(string sectionId)
    {
        await JS.InvokeVoidAsync("scrollToSection", sectionId);
    }

    private async Task NavigateProjects() => await ScrollToSection("projects");
    private async Task NavigateSkills() => await ScrollToSection("skills");
    private async Task NavigateContact() => await ScrollToSection("contact");
}
