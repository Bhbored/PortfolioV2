@using Portfolio.Mockdata
@using Portfolio.Models
@inject NavigationManager Navigation

<div class="nav-menu-container">
    <nav class="fixed top-0 w-full h-[80px] z-50 bg-[#0a0a0f]/80 backdrop-blur-xl shadow-[0_0_20px_rgba(0,240,255,0.08)] flex justify-between items-center px-6 md:px-12 w-full max-w-none animate-fade-in-down">
        <div class="absolute inset-0 grid-pattern opacity-20 pointer-events-none"></div>

        <!-- Logo -->
        <div class="relative group animate-fade-in-left" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">
            <div class="flex items-center gap-4">
                <a href="/" class="w-10 h-10 border-2 border-primary-container flex items-center justify-center font-headline text-2xl font-bold text-primary-container p-1 leading-none relative hover:scale-110 transition-transform duration-300">
                    @info.Name
                    <svg class="absolute -top-4 -right-4 w-8 h-8 opacity-0 group-hover:opacity-100 transition-opacity" viewbox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" fill="none" stroke="#00f0ff" stroke-width="1"></path>
                        <path d="M13 6l-1-1-1 1m1 12l1 1 1-1" fill="none" stroke="#00f0ff" stroke-width="2"></path>
                        <path d="M12 5v14" fill="none" stroke="#00f0ff" stroke-dasharray="2 2" stroke-width="1"></path>
                    </svg>
                </a>
            </div>
        </div>

        <!-- Desktop Navigation Links -->
        <div class="hidden md:flex items-center gap-8 font-body text-sm tracking-widest uppercase">
            @foreach (var navItem in navItems)
            {
                var isActive = currentSection == navItem;
                <a class="transition-all duration-300 hover:scale-105 relative group @(isActive ? "text-primary-container" : "text-white/70 hover:text-primary-container")"
                   href="@($"#{navItem.ToLower()}")"
                   @onclick="() => SetActiveSection(navItem)">
                    @navItem
                    <span class="absolute -bottom-2 left-0 w-full h-[2px] bg-primary-container @(isActive ? "" : "scale-x-0") group-hover:scale-x-100 transition-transform duration-300"></span>
                </a>
            }
        </div>
        
        <!-- Mobile Menu Button -->
        <button class="md:hidden flex flex-col gap-1.5 z-50 p-2" @onclick="ToggleMobileMenu" aria-label="Toggle menu">
            <span class="w-6 h-0.5 bg-primary-container transition-all duration-300 @(isMobileMenuOpen ? "rotate-45 translate-y-2" : "")"></span>
            <span class="w-6 h-0.5 bg-primary-container transition-all duration-300 @(isMobileMenuOpen ? "opacity-0" : "")"></span>
            <span class="w-6 h-0.5 bg-primary-container transition-all duration-300 @(isMobileMenuOpen ? "-rotate-45 -translate-y-2" : "")"></span>
        </button>
        
        <!-- Desktop CTA -->
        <div class="hidden md:block relative group" style="animation: fadeInRight 0.6s ease-out 700ms forwards; opacity: 0;">
            <button class="px-8 py-2.5 rounded-full border border-transparent bg-gradient-to-r from-primary-container to-secondary-container p-[1px] hover:scale-105 active:scale-95 transition-all duration-300" @onclick="@(() => NavigateTo("Contact"))">
                <div class="bg-[#0a0a0f] px-8 py-2 rounded-full h-full w-full flex items-center justify-center">
                    <span class="font-headline text-sm font-bold tracking-widest uppercase text-white">Let's Talk</span>
                </div>
            </button>
            <div class="absolute -inset-4 border border-dashed border-primary-container/20 rounded-full scale-150 opacity-0 group-hover:opacity-100 group-hover:scale-100 transition-all duration-700 pointer-events-none"></div>
        </div>
    </nav>
    
    <!-- Mobile Menu Overlay -->
    <div class="fixed inset-0 bg-[#0a0a0f]/95 backdrop-blur-xl z-40 md:hidden transition-all duration-500 @(isMobileMenuOpen ? "opacity-100 visible" : "opacity-0 invisible pointer-events-none")">
        <div class="flex flex-col items-center justify-center h-full w-full px-6">
            <div class="flex flex-col gap-8 text-center">
                @foreach (var navItem in navItems)
                {
                    var isActive = currentSection == navItem;
                    <a class="font-body text-2xl tracking-widest uppercase transition-all duration-300 hover:scale-110 @(isActive ? "text-primary-container" : "text-white/70 hover:text-primary-container")"
                           href="@(() => navItem.Equals("Home",StringComparison.OrdinalIgnoreCase) ? "/" : ($"#{navItem.ToLower()}"))"
                       @onclick="() => { SetActiveSection(navItem); CloseMobileMenu(); }">
                        @navItem
                    </a>
                }
                <button class="mt-8 px-12 py-4 rounded-full border border-transparent bg-gradient-to-r from-primary-container to-secondary-container p-[1px] hover:scale-105 active:scale-95 transition-all duration-300"
                        @onclick="@(() => NavigateTo("Contact"))">
                    <div class="bg-[#0a0a0f] px-12 py-4 rounded-full h-full w-full flex items-center justify-center">
                        <span class="font-headline text-sm font-bold tracking-widest uppercase text-white">Let's Talk</span>
                    </div>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly PersonalInfo info = PersonalInfoData.GetDeveloper();
    private bool isMobileMenuOpen = false;
    private string currentSection = "Home";

    private readonly List<string> navItems = new() { "Home", "Skills", "Projects", "Experience", "Certificates", "Education", "Contact" };

    private void SetActiveSection(string section)
    {
        currentSection = section;
    }

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        isMobileMenuOpen = false;
    }

    private void NavigateTo(string section)
    {
        isMobileMenuOpen = false;
        Navigation.NavigateTo($"#{section.ToLower()}");
    }
}
