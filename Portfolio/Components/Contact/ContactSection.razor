@using Portfolio.Models
@using Portfolio.Models.Enums
@inject NavigationManager Navigator

<section id="contact" class="relative w-full py-16 md:py-24 px-6 md:px-12 overflow-hidden">
    <!-- Main Content -->
    <div class="relative z-10 max-w-screen-2xl mx-auto">
        <!-- Impact Headline -->
        <div class="mb-12 md:mb-16">
            <div class="space-y-0">
                <div class="overflow-hidden">
                    <h1 class="font-headline font-bold text-[48px] md:text-[64px] lg:text-[80px] leading-[0.9] tracking-tight text-white uppercase animate-fade-in-up" style="animation-delay: 100ms; animation-fill-mode: both; opacity: 0;">
                        LET'S BUILD
                    </h1>
                </div>
                <div class="overflow-hidden">
                    <h1 class="font-headline font-bold text-[48px] md:text-[64px] lg:text-[80px] leading-[0.9] tracking-tight text-primary text-glow-cyan uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">
                        SOMETHING
                    </h1>
                </div>
                <div class="overflow-hidden">
                    <h1 class="font-headline font-bold text-[48px] md:text-[64px] lg:text-[80px] leading-[0.9] tracking-tight text-secondary text-glow-orange uppercase animate-fade-in-up" style="animation-delay: 300ms; animation-fill-mode: both; opacity: 0;">
                        GREAT
                    </h1>
                </div>
            </div>
        </div>

        <!-- Two Cards Row (Centered Horizontally) -->
        <div class="flex flex-col md:flex-row items-stretch justify-center gap-8 md:gap-12 lg:gap-16">
            <!-- Flip Card -->
            <div class="w-full md:w-1/2 max-w-lg animate-fade-in-up flip-card-wrapper" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                <div class="flip-card-container w-full min-h-[500px] md:min-h-[600px]">
                    <!-- Card Inner -->
                    <div class="flip-card-inner w-full h-full @(isFlipped ? "flipped" : "")" style="@(isFlipped ? "transform: rotateY(180deg);" : "")">
                        <!-- Front: Info -->
                        <div class="flip-card-front bg-surface-container-high rounded-xl border border-white/10 p-6 md:p-8 flex flex-col">
                            <h3 class="font-headline text-xl md:text-2xl font-bold uppercase tracking-tight text-white mb-4">Let's Work Together!</h3>
                            <p class="font-body text-on-surface-variant text-sm leading-relaxed mb-8">I'm currently available for freelance work and open to discussing new projects, collaborations, or opportunities to be part of your vision.</p>

                            <div class="space-y-8 flex-grow flex flex-col justify-center mb-8">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                        <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="font-label text-sm font-bold text-primary uppercase tracking-wider">Quick Response</p>
                                        <p class="font-body text-sm text-on-surface-variant mt-1">I typically respond within 24 hours</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                        <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    </div>
                                    <div>
                                        <p class="font-label text-sm font-bold text-primary uppercase tracking-wider">Flexible Schedule</p>
                                        <p class="font-body text-sm text-on-surface-variant mt-1">Available for remote work and flexible hours</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                        <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                                    </div>
                                    <div>
                                        <p class="font-label text-sm font-bold text-primary uppercase tracking-wider">Project Types</p>
                                        <p class="font-body text-sm text-on-surface-variant mt-1">Mobile apps, cross-platform development, consulting</p>
                                    </div>
                                </div>
                            </div>

                            <button type="button" class="w-full h-14 bg-gradient-to-r from-primary to-secondary flex items-center justify-center gap-3 font-headline font-bold text-background uppercase tracking-tight hover:scale-102 active:scale-95 transition-all duration-300 mt-auto" @onclick="FlipToForm">
                                SEND ME AN EMAIL
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </button>
                        </div>

                        <!-- Back: Form -->
                        <div class="flip-card-back bg-surface-container-high rounded-xl border border-white/10 p-6 md:p-8 flex flex-col">
                            <h3 class="font-headline text-xl md:text-2xl font-bold uppercase tracking-tight text-white mb-6">Send Me A Message</h3>
                            
                            <EditForm Model="@contactModel" OnValidSubmit="HandleSubmit" FormName="contact-form" class="space-y-6 flex-grow flex flex-col">
                                <DataAnnotationsValidator />

                                <div class="relative flex-grow">
                                    <InputText @bind-Value="@contactModel.Name" class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 text-on-surface focus:border-primary focus:ring-0 transition-all duration-300 placeholder-transparent" placeholder="Name" />
                                    <label class="absolute left-0 top-3 font-label text-on-surface uppercase tracking-widest text-xs pointer-events-none transition-all duration-300 origin-left peer-focus:-translate-y-8 peer-focus:scale-75 peer-focus:text-primary peer-[:not(:placeholder-shown)]:-translate-y-8 peer-[:not(:placeholder-shown)]:scale-75">NAME</label>
                                    <ValidationMessage For="@(() => contactModel.Name)" class="block text-xs text-red-500 mt-1 font-label tracking-wider" />
                                </div>

                                <div class="relative flex-grow">
                                    <InputText @bind-Value="@contactModel.Subject" class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 text-on-surface focus:border-primary focus:ring-0 transition-all duration-300 placeholder-transparent" placeholder="Subject" />
                                    <label class="absolute left-0 top-3 font-label text-on-surface uppercase tracking-widest text-xs pointer-events-none transition-all duration-300 origin-left peer-focus:-translate-y-8 peer-focus:scale-75 peer-focus:text-primary peer-[:not(:placeholder-shown)]:-translate-y-8 peer-[:not(:placeholder-shown)]:scale-75">SUBJECT</label>
                                    <ValidationMessage For="@(() => contactModel.Subject)" class="block text-xs text-red-500 mt-1 font-label tracking-wider" />
                                </div>

                                <div class="relative flex-grow">
                                    <InputTextArea @bind-Value="@contactModel.Message" class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 text-on-surface focus:border-primary focus:ring-0 transition-all duration-300 resize-none placeholder-transparent" placeholder="Message" rows="4" />
                                    <label class="absolute left-0 top-3 font-label text-on-surface uppercase tracking-widest text-xs pointer-events-none transition-all duration-300 origin-left peer-focus:-translate-y-8 peer-focus:scale-75 peer-focus:text-primary peer-[:not(:placeholder-shown)]:-translate-y-8 peer-[:not(:placeholder-shown)]:scale-75">MESSAGE</label>
                                    <ValidationMessage For="@(() => contactModel.Message)" class="block text-xs text-red-500 mt-1 font-label tracking-wider" />
                                </div>

                                <button type="submit" class="w-full h-14 bg-gradient-to-r from-primary to-secondary flex items-center justify-center gap-3 font-headline font-bold text-background uppercase tracking-tight hover:scale-102 active:scale-95 transition-all duration-300 mt-auto">
                                    SEND MESSAGE
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </button>
                            </EditForm>

                            <button type="button" class="mt-4 w-full py-3 text-center text-xs font-label text-on-surface-variant/50 hover:text-primary transition-colors tracking-widest uppercase border border-white/10 rounded-lg hover:border-primary/50" @onclick="FlipToInfo">
                                ← BACK TO INFO
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Contact Info + Languages Cards -->
            <div class="w-full md:w-1/2 max-w-lg flex flex-col gap-6 animate-fade-in-up" style="animation-delay: 500ms; animation-fill-mode: both; opacity: 0;">
                <!-- Contact Information Card -->
                <div class="bg-surface-container-high rounded-xl border border-white/10 p-6 md:p-8">
                    <h3 class="contact-gradient-title font-headline text-lg font-bold uppercase tracking-tight mb-6">Contact Information</h3>
                    
                    <div class="space-y-5">
                        @if (!string.IsNullOrEmpty(info.Email))
                        {
                            <div class="flex items-start gap-3">
                                <svg class="contact-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                <div>
                                    <p class="font-label text-xs uppercase tracking-widest text-primary mb-1">Email</p>
                                    <a href="mailto:@info.Email" class="font-body text-sm text-on-surface-variant hover:text-primary transition-colors hover:underline">@info.Email</a>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(info.Phone))
                        {
                            <div class="flex items-start gap-3">
                                <svg class="contact-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                <div>
                                    <p class="font-label text-xs uppercase tracking-widest text-primary mb-1">Phone</p>
                                    <a href="tel:@info.Phone" class="font-body text-sm text-on-surface-variant hover:text-primary transition-colors hover:underline">@info.Phone</a>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(info.Location))
                        {
                            <div class="flex items-start gap-3">
                                <svg class="contact-info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                <div>
                                    <p class="font-label text-xs uppercase tracking-widest text-primary mb-1">Location</p>
                                    <p class="font-body text-sm text-on-surface-variant">@info.Location</p>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Social Links -->
                    <div class="flex gap-4 mt-6 pt-6 border-t border-white/10">
                        @if (!string.IsNullOrEmpty(info.Social.Github))
                        {
                            <a href="@info.Social.Github" target="_blank" rel="noopener noreferrer" class="contact-social-link">
                                <svg class="contact-social-icon" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(info.Social.Linkedin))
                        {
                            <a href="@info.Social.Linkedin" target="_blank" rel="noopener noreferrer" class="contact-social-link">
                                <svg class="contact-social-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                            </a>
                        }
                    </div>
                </div>

                <!-- Languages Card -->
                <div class="bg-surface-container-high rounded-xl border border-white/10 p-6 md:p-8 flex-grow">
                    <h3 class="contact-gradient-title font-headline text-lg font-bold uppercase tracking-tight mb-6">Languages</h3>
                    
                    <div class="space-y-4">
                        @foreach (var lang in info.Languages)
                        {
                            <div class="flex justify-between items-start">
                                <p class="font-body text-sm text-on-surface-variant font-medium">@lang.Name</p>
                                <p class="font-label text-xs text-primary uppercase tracking-wider">@GetProficiencyText(lang.Proficiency)</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public required PersonalInfo Info { get; set; }

    private PersonalInfo info => Info;
    private ContactFormModel contactModel = new();
    private bool isFlipped = false;

    private async Task HandleSubmit()
    {
        await Task.Delay(100);
        await SendEmail();
        contactModel = new ContactFormModel();
        isFlipped = false;
    }

    async Task SendEmail()
    {
        var subject = $"{contactModel.Subject}";
        var body = $@"
Hello, my name is {contactModel.Name} and I would like to get in touch with you.
{contactModel.Message}";

        var mailto = $"mailto:{info.Email}?subject={Uri.EscapeDataString(subject)}&body={Uri.EscapeDataString(body)}";

        Navigator.NavigateTo(mailto);
    }

    private void FlipToForm() => isFlipped = true;
    private void FlipToInfo() => isFlipped = false;

    private static string GetProficiencyText(ProficiencyLevel proficiency)
    {
        return proficiency switch
        {
            ProficiencyLevel.Elementary => "Elementary Proficiency",
            ProficiencyLevel.Intermediate => "Intermediate Proficiency",
            ProficiencyLevel.Advanced => "Advanced Proficiency",
            ProficiencyLevel.Native => "Native",
            _ => proficiency.ToString()
        };
    }
}
