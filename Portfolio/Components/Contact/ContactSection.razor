@using Portfolio.Models
@inject NavigationManager Navigator
<section id="contact" class="relative w-full py-24 md:py-40 px-6 md:px-12 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-1/4 -right-20 w-64 md:w-96 h-64 md:h-96 bg-primary/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 -left-20 w-64 md:w-96 h-64 md:h-96 bg-secondary/5 rounded-full blur-[120px]"></div>
    </div>

    <!-- Main Content -->
    <div class="relative z-10 max-w-screen-2xl mx-auto">
        <!-- Impact Headline (Top Centered) -->
        <div class="text-center mb-16 md:mb-24">
            <div class="space-y-0 inline-block">
                <div class="overflow-hidden">
                    <h1 class="font-headline font-bold text-[48px] md:text-[64px] lg:text-[80px] leading-[0.9] tracking-tight text-white uppercase animate-fade-in-up" style="animation-delay: 100ms; animation-fill-mode: both; opacity: 0;">
                        LET'S BUILD
                    </h1>
                </div>
                <div class="overflow-hidden">
                    <h1 class="font-headline font-bold text-[48px] md:text-[64px] lg:text-[80px] leading-[0.9] tracking-tight text-primary text-glow-cyan uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">
                        SOMETHING
                    </h1>
                </div>
                <div class="overflow-hidden">
                    <h1 class="font-headline font-bold text-[48px] md:text-[64px] lg:text-[80px] leading-[0.9] tracking-tight text-secondary text-glow-orange uppercase animate-fade-in-up" style="animation-delay: 300ms; animation-fill-mode: both; opacity: 0;">
                        GREAT
                    </h1>
                </div>
            </div>
        </div>

        <!-- Two Cards Row (Centered Horizontally) -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12 lg:gap-16">
            <!-- Contact Form Card (Left) -->
            <div class="w-full md:w-1/2 max-w-lg animate-fade-in-up" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                <div class="relative p-[2px] rounded-xl bg-gradient-to-br from-primary via-secondary/50 to-primary animate-pulse-slow">
                    <div class="bg-surface-container-low/40 backdrop-blur-xl p-6 md:p-10 rounded-xl shadow-2xl shadow-glow-cyan/20">
                        <EditForm Model="@contactModel" OnValidSubmit="HandleSubmit" FormName="contact-form" class="space-y-8 md:space-y-10">
                            <DataAnnotationsValidator />

                            <!-- Field: Name -->
                            <div class="relative group">
                                <InputText @bind-Value="@contactModel.Name"
                                           class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 text-on-surface focus:border-primary focus:ring-0 transition-all duration-300 placeholder-transparent"
                                           placeholder="Name" />
                                <label class="absolute left-0 top-3 font-label text-on-surface uppercase tracking-widest text-xs pointer-events-none transition-all duration-300 origin-left peer-focus:-translate-y-8 peer-focus:scale-75 peer-focus:text-primary peer-[:not(:placeholder-shown)]:-translate-y-8 peer-[:not(:placeholder-shown)]:scale-75">
                                    NAME
                                </label>
                                <ValidationMessage For="@(() => contactModel.Name)" class="text-secondary text-xs mt-1 block" />
                            </div>

                            <!-- Field: Subject -->
                            <div class="relative group">
                                <InputText @bind-Value="@contactModel.Subject"
                                           class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 text-on-surface focus:border-primary focus:ring-0 transition-all duration-300 placeholder-transparent"
                                           placeholder="Subject" />
                                <label class="absolute left-0 top-3 font-label text-on-surface uppercase tracking-widest text-xs pointer-events-none transition-all duration-300 origin-left peer-focus:-translate-y-8 peer-focus:scale-75 peer-focus:text-primary peer-[:not(:placeholder-shown)]:-translate-y-8 peer-[:not(:placeholder-shown)]:scale-75">
                                    SUBJECT
                                </label>
                                <ValidationMessage For="@(() => contactModel.Subject)" class="text-secondary text-xs mt-1 block" />
                            </div>

                            <!-- Field: Message -->
                            <div class="relative group">
                                <InputTextArea @bind-Value="@contactModel.Message"
                                               class="peer w-full bg-transparent border-0 border-b border-outline-variant py-3 text-on-surface focus:border-primary focus:ring-0 transition-all duration-300 resize-none placeholder-transparent"
                                               placeholder="Message"
                                               rows="4" />
                                <label class="absolute left-0 top-3 font-label text-on-surface uppercase tracking-widest text-xs pointer-events-none transition-all duration-300 origin-left peer-focus:-translate-y-8 peer-focus:scale-75 peer-focus:text-primary peer-[:not(:placeholder-shown)]:-translate-y-8 peer-[:not(:placeholder-shown)]:scale-75">
                                    MESSAGE
                                </label>
                                <ValidationMessage For="@(() => contactModel.Message)" class="text-secondary text-xs mt-1 block" />
                            </div>

                            <!-- Submit Button -->
                            <button type="submit"
                                    class="w-full h-14 bg-gradient-to-r from-primary to-secondary flex items-center justify-center gap-3 font-headline font-bold text-background uppercase tracking-tight hover:scale-102 active:scale-95 transition-all duration-300 group shadow-glow-cyan">
                                SEND MESSAGE
                                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                </svg>
                            </button>
                        </EditForm>
                    </div>
                </div>
            </div>

            <!-- Info Card (Right) -->
            <div class="w-full md:w-1/2 max-w-lg animate-fade-in-up" style="animation-delay: 500ms; animation-fill-mode: both; opacity: 0;">
                <div class="space-y-8 md:space-y-10">
                    <!-- Social Links -->
                    <div class="flex gap-4 md:gap-6">
                        @if (!string.IsNullOrEmpty(info.Social.Github))
                        {
                            <a href="@info.Social.Github" target="_blank" rel="noopener noreferrer"
                               class="w-12 h-12 md:w-14 md:h-14 rounded-full border border-outline-variant flex items-center justify-center text-primary hover:bg-primary hover:text-background transition-all duration-300 hover:scale-102 hover:shadow-glow-cyan group">
                                <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                                </svg>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(info.Social.Linkedin))
                        {
                            <a href="@info.Social.Linkedin" target="_blank" rel="noopener noreferrer"
                               class="w-12 h-12 md:w-14 md:h-14 rounded-full border border-outline-variant flex items-center justify-center text-primary hover:bg-primary hover:text-background transition-all duration-300 hover:scale-102 hover:shadow-glow-cyan group">
                                <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                                </svg>
                            </a>
                        }
                    </div>

                    <!-- Location & Availability -->
                    <div>
                        <p class="font-body text-on-surface-variant max-w-md leading-relaxed text-base md:text-lg">
                            @if (!string.IsNullOrEmpty(info.Location))
                            {
                                <span class="block">@info.Location</span>
                            }
                            @if (info.IsAvailableForWork)
                            {
                                <span class="block text-primary mt-2">Available for new opportunities</span>
                            }
                        </p>
                    </div>

                    <!-- Contact Info -->
                    <div class="space-y-3 md:space-y-4">
                        @if (!string.IsNullOrEmpty(info.Email))
                        {
                            <button @onclick="SendEmail" class="flex items-center gap-3 text-on-surface-variant hover:text-primary transition-colors duration-300 group">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                                <span class="font-body text-sm md:text-base group-hover:underline">@info.Email</span>
                            </button>
                        }
                        @if (!string.IsNullOrEmpty(info.Phone))
                        {
                            <a href="tel:@info.Phone" class="flex items-center gap-3 text-on-surface-variant hover:text-primary transition-colors duration-300 group">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                </svg>
                                <span class="font-body text-sm md:text-base group-hover:underline">@info.Phone</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public required PersonalInfo Info { get; set; }

    private PersonalInfo info => Info;
    private ContactFormModel contactModel = new();

    private async Task HandleSubmit()
    {
        // TODO: Implement actual form submission logic
        await Task.Delay(100);
        await SendEmail();
        contactModel = new ContactFormModel();
    }

    async Task SendEmail()
    {
        var subject = $"{contactModel.Subject}";
        var body = $@"
Hello, my name is {contactModel.Name} and I would like to get in touch with you.
{contactModel.Message}";

        var mailto = $"mailto:bhbored2022@gmail.com?subject={Uri.EscapeDataString(subject)}&body={Uri.EscapeDataString(body)}";
        
        Navigator.NavigateTo(mailto);
    }
    
}
