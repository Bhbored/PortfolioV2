@using Portfolio.Models

<div class="relative bg-surface-container-low border-l-[3px] border-primary-container p-6 md:p-8 flex flex-col justify-between h-[360px] w-fit max-w-[420px] transition-all duration-300 hover:translate-x-2 hover:shadow-glow-cyan hover:border-l-4 animate-fade-in-up" style="animation-delay: @(Index * 150)ms; animation-fill-mode: both; opacity: 0;">
    <div class="flex justify-between items-start mb-4">
        <span class="material-symbols-outlined text-primary-container text-3xl md:text-4xl transition-transform duration-300 group-hover:scale-110">verified</span>
        <span class="font-label text-[12px] text-slate-600 tracking-widest">REF: @(Index + 1)</span>
    </div>

    <div class="space-y-1 mb-6">
        <h3 class="font-headline text-lg md:text-xl font-bold uppercase tracking-tight text-white mb-1">@Certificate.Title</h3>
        <p class="font-body text-xs md:text-sm text-slate-400">@Certificate.Issuer &bull; @Certificate.Year</p>
    </div>

    <!-- Top 3 Skills with Mastery Bars -->
    <div class="space-y-3 mt-auto">
        @foreach (var skill in Certificate.TopSkills)
        {
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-[12px] font-label tracking-widest text-slate-500 uppercase">@skill.Title</span>
                    <span class="text-[12px] font-label text-slate-400">@skill.MasteryLevel%</span>
                </div>
                <div class="h-0.5 bg-surface-container-highest w-full relative overflow-hidden">
                    <div class="absolute h-full bg-primary" style="width: @skill.MasteryLevel%; box-shadow: 0 0 8px rgba(0, 240, 255, 0.3);"></div>
                </div>
            </div>
        }
    </div>

    <!-- Credential Link (if available) -->
    @if (!string.IsNullOrEmpty(Certificate.Link))
    {
        <div class="mt-4 pt-3 border-t border-white/5">
            <a href="@Certificate.Link" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-[10px] font-label text-primary/60 hover:text-primary transition-colors tracking-widest uppercase">
                <span>Verify Credential</span>
                <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required Certificate Certificate { get; set; }
    [Parameter, EditorRequired] public required int Index { get; set; }
}
