@using Portfolio.Models

<div class="group relative bg-gradient-to-br from-surface-container-low via-surface-container to-surface-container-high border-l-[3px] border-primary-container p-6 md:p-8 flex flex-col justify-between h-[360px] w-fit max-w-[420px] transition-all duration-500 hover:translate-x-2 hover:shadow-glow-cyan hover:border-l-4 animate-fade-in-up overflow-hidden" style="animation-delay: @(Index * 150)ms; animation-fill-mode: both; opacity: 0;">
    <!-- Animated Gradient Sweep on Hover -->
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-primary/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out pointer-events-none"></div>

    <!-- Top Glow Line -->
    <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-primary/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

    <!-- Right Edge Glow -->
    <div class="absolute top-0 bottom-0 right-0 w-[2px] bg-primary/0 group-hover:bg-primary/30 transition-colors duration-500"></div>

    <div class="flex justify-between items-start mb-4 relative z-10">
        <span class="material-symbols-outlined text-primary-container text-3xl md:text-4xl transition-transform duration-300 group-hover:scale-110 group-hover:animate-pulse">verified</span>
        <span class="font-label text-[12px] text-slate-600 tracking-widest">REF: @(Index + 1)</span>
    </div>

    <div class="space-y-1 mb-6 relative z-10">
        <h3 class="font-headline text-lg md:text-xl font-bold uppercase tracking-tight text-white mb-1 group-hover:text-gradient transition-all duration-500">@Certificate.Title</h3>
        <p class="font-body text-xs md:text-sm text-slate-400">@Certificate.Issuer &bull; @Certificate.Year</p>
    </div>

    <!-- Top 3 Skills with Mastery Bars -->
    <div class="space-y-3 mt-auto relative z-10">
        @foreach (var skill in Certificate.TopSkills)
        {
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-[12px] font-label tracking-widest text-slate-500 uppercase group-hover:text-slate-400 transition-colors duration-500">@skill.Title</span>
                    <span class="text-[12px] font-label text-slate-400 group-hover:text-primary/80 transition-colors duration-500">@skill.MasteryLevel%</span>
                </div>
                <div class="h-0.5 bg-surface-container-highest w-full relative overflow-hidden">
                    <div class="absolute h-full bg-primary" style="width: @skill.MasteryLevel%; box-shadow: 0 0 8px rgba(0, 240, 255, @ShadowOpacity);"></div>
                </div>
            </div>
        }
    </div>

    <!-- Bottom Decorative Dots -->
    <div class="absolute bottom-3 right-3 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
        <span class="w-1 h-1 rounded-full bg-primary/60"></span>
        <span class="w-1 h-1 rounded-full bg-primary/40"></span>
        <span class="w-1 h-1 rounded-full bg-primary/20"></span>
    </div>

    <!-- Credential Link (if available) -->
    @if (!string.IsNullOrEmpty(Certificate.Link))
    {
        <div class="mt-4 pt-3 border-t border-white/5 relative z-10">
            <a href="@Certificate.Link" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-[10px] font-label text-primary/60 hover:text-primary transition-colors tracking-widest uppercase">
                <span>Verify Credential</span>
                <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required Certificate Certificate { get; set; }
    [Parameter, EditorRequired] public required int Index { get; set; }

    private string ShadowOpacity => Index % 2 == 0 ? "0.3" : "0.1";
}
