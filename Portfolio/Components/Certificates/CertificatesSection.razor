@using Portfolio.Models
@using Portfolio.Contracts
@inject ISkillService SkillService
@inject IModelToJsonService ModelToJsonService
@inject IJSRuntime JS

<section id="certificates" class="min-h-screen pt-16 md:pt-24 pb-20 md:pb-24 px-4 md:px-6 lg:px-8 relative">
    <!-- Atmospheric Background Mesh -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none opacity-20 -z-10 mesh-gradient">
        <div class="absolute top-1/4 right-1/4 w-64 md:w-96 h-64 md:h-96 bg-primary/10 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-1/4 left-1/4 w-80 md:w-[500px] h-80 md:h-[500px] bg-accent-orange/5 blur-[150px] rounded-full"></div>
    </div>

    <!-- Header Section -->
    <header class="mb-16 md:mb-24 relative">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="inline-block relative">
                <span class="absolute -top-4 md:-top-6 left-0 font-label text-[8px] md:text-[10px] tracking-[0.4em] text-primary/40 uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">// VERIFIED_CREDENTIALS</span>
                <h1 class="font-headline text-[48px] md:text-[80px] lg:text-[96px] font-black tracking-tighter uppercase leading-none animate-fade-in-left" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                    CERTIFIED<br /><span class="text-primary">COMPETENCE</span>
                </h1>
            </div>
            <div class="max-w-xs md:text-right border-r-2 md:border-r-0 md:border-l-2 border-primary/20 md:pl-6 pr-4 md:pr-0">
                <p class="text-slate-400 text-xs md:text-sm leading-relaxed animate-fade-in-up" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                    Professional certifications and technical achievements.
                </p>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-2 animate-fade-in-up" style="animation-delay: 800ms; animation-fill-mode: both; opacity: 0;">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
            <span class="font-label text-[10px] tracking-[0.3em] uppercase text-slate-500">@(certificateData?.Count ?? 0) Credentials Verified</span>
        </div>
    </header>

    <!-- Certificates Manual Scroll Track -->
    @if (certificateData != null && certificateData.Any())
    {
        <div class="max-w-screen-2xl mx-auto relative">
            <div class="cert-track">
                <div class="cert-track-inner py-4" id="certificates-track">
                    @for (int i = 0; i < certificateData.Count; i++)
                    {
                        var data = certificateData[i];
                        <div class="cert-card-wrapper">
                            <CertificateCard Certificate="@data" Index="@i" TopSkills="data.TopSKills" />
                        </div>
                    }
                </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="flex justify-between items-center mt-12 hidden md:flex">
                <button @onclick="PreviousPage"
                        disabled="@(currentIndex == 0)"
                        class="px-6 py-3 bg-surface-container-high border border-outline-variant/30 text-primary font-label text-xs tracking-widest uppercase hover:border-primary/50 hover:shadow-glow-cyan transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-sm mr-2">arrow_back</span>
                    Previous
                </button>

                <span class="text-on-surface-variant font-label text-xs tracking-widest">
                    @($"{currentIndex / PageSize + 1} / {(certificateData.Count + PageSize - 1) / PageSize}")
                </span>

                <button @onclick="NextPage"
                        disabled="@(currentIndex + PageSize >= certificateData.Count)"
                        class="px-6 py-3 bg-surface-container-high border border-outline-variant/30 text-primary font-label text-xs tracking-widest uppercase hover:border-primary/50 hover:shadow-glow-cyan transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed">
                    Next
                    <span class="material-symbols-outlined text-sm ml-2">arrow_forward</span>
                </button>
            </div>
        </div>
    }
</section>

@code {
    private List<Certificate> certificateData = [];
    private int currentIndex = 0;
    private const int PageSize = 4;

    protected override async Task OnInitializedAsync()
    {
        certificateData = await ModelToJsonService.GetCertificatesAsync();

        foreach (var c in certificateData)
        {
            c.TopSKills = await SkillService.GetTop3SkillsByCertificateId(c.Id);
        }
    }

    private async Task NextPage()
    {
        if (currentIndex + PageSize < certificateData.Count)
        {
            currentIndex += PageSize;
            await JS.InvokeVoidAsync("slideCertsTrack", currentIndex);
        }
    }

    private async Task PreviousPage()
    {
        if (currentIndex - PageSize >= 0)
        {
            currentIndex -= PageSize;
            await JS.InvokeVoidAsync("slideCertsTrack", currentIndex);
        }
    }
}
