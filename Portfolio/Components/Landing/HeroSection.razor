@using Portfolio.Models

<section class="relative h-screen w-full flex items-center px-6 md:px-12 mesh-gradient overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

  

    <!-- Content Container -->
    <div class="w-full max-w-screen-2xl mx-auto h-full flex items-center">
        <!-- Desktop Layout: Side by side -->
        <div class="hidden md:flex flex-row items-center gap-12 w-full">
            <!-- Left Content (60%) -->
            <div class="w-full md:w-3/5 relative z-10 flex flex-col items-start pt-20">
                <div class="flex flex-col gap-0">
                    <!-- Main Headline -->
                    <div class="relative">
                        <h1 class="font-headline text-[72px] md:text-[96px] lg:text-[120px] font-bold text-white leading-[0.85] tracking-tight group animate-fade-in-left" style="animation-delay: 300ms; animation-fill-mode: both; opacity: 0;">
                            @foreach (var (letter, index) in info.Name.Select((c, i) => (c, i)))
                            {
                                <span class="inline-block relative hover:-translate-y-2 transition-transform duration-300">
                                    @letter
                                    <span class="absolute -top-8 left-0 opacity-0 group-hover:opacity-100 transition-opacity text-primary text-xs" style="transition-delay: @(index * 50)ms">↑</span>
                                </span>
                            }
                        </h1>
                        <h1 class="font-headline text-[72px] md:text-[96px] lg:text-[120px] font-bold text-gradient leading-[0.85] tracking-tight mt-4 animate-fade-in-left" style="animation-delay: 500ms; animation-fill-mode: both; opacity: 0;">
                            @info.Title
                        </h1>
                    </div>
                </div>

                <!-- Secondary Info -->
                <div class="mt-16 md:mt-24 flex items-center gap-8 md:gap-12">
                    @if (info.IsAvailableForWork)
                    {
                        <AvailabilityBadge />
                    }
                    <div class="max-w-xs animate-fade-in-up" style="animation-delay: 700ms; animation-fill-mode: both; opacity: 0;">
                        <p class="font-body text-white/40 text-sm leading-relaxed">
                            @info.Summary
                        </p>
                    </div>
                </div>
            </div>

            <!-- Right Content (40%) - Portrait -->
            <div class="hidden md:block w-full md:w-2/5 h-[70vh] relative animate-fade-in-right" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                <PortraitSection PortraitUrl="@info.ProfileImage" />
            </div>
        </div>

        <!-- Mobile Layout: Stacked -->
        <div class="flex md:hidden flex-col items-center justify-center w-full pt-20 pb-12">
            <!-- Left Content (Full Width) -->
            <div class="w-full flex flex-col items-center text-center">
                <div class="flex flex-col gap-0">
                    <!-- Main Headline - Smaller on mobile -->
                    <div class="relative">
                        <h1 class="font-headline text-[64px] font-bold text-white leading-[0.9] tracking-tight animate-fade-in-up" style="animation-delay: 300ms; animation-fill-mode: both; opacity: 0;">
                            @info.Name
                        </h1>
                        <h1 class="font-headline text-[64px] font-bold text-gradient leading-[0.9] tracking-tight mt-2 animate-fade-in-up" style="animation-delay: 500ms; animation-fill-mode: both; opacity: 0;">
                            @info.Title
                        </h1>
                    </div>
                </div>

                <!-- Secondary Info -->
                <div class="mt-8 flex flex-col items-center gap-6">
                    @if (info.IsAvailableForWork)
                    {
                        <AvailabilityBadge />
                    }
                    <div class="max-w-sm animate-fade-in-up" style="animation-delay: 700ms; animation-fill-mode: both; opacity: 0;">
                        <p class="font-body text-white/40 text-sm leading-relaxed">
                            @info.Summary
                        </p>
                    </div>
                </div>
            </div>

            <!-- Right Content (Portrait - Smaller on mobile) -->
            <div class="w-full h-[40vh] mt-8 relative animate-scale-in" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                <PortraitSection PortraitUrl="@info.ProfileImage" />
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <ScrollIndicator />
</section>

@code {
    [Parameter, EditorRequired] public required PersonalInfo Info { get; set; }

    private PersonalInfo info => Info;
}
