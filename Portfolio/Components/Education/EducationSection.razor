@using Portfolio.Models
@using Portfolio.Mockdata

<section id="education" class="min-h-screen pt-32 md:pt-40 pb-40 px-6 relative">
    <!-- Atmospheric Background Mesh -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none opacity-20 -z-10 mesh-gradient">
        <div class="absolute top-1/3 right-1/3 w-64 md:w-96 h-64 md:h-96 bg-primary/8 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-1/3 left-1/3 w-80 md:w-[500px] h-80 md:h-[500px] bg-accent-orange/5 blur-[150px] rounded-full"></div>
    </div>

    <!-- Header -->
    <header class="mb-16 md:mb-24 relative">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="inline-block relative">
                <span class="absolute -top-4 md:-top-6 left-0 font-label text-[8px] md:text-[10px] tracking-[0.4em] text-primary/40 uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">// ACADEMIC_FOUNDATION</span>
                <h1 class="font-headline text-[48px] md:text-[80px] lg:text-[96px] font-black tracking-tighter uppercase leading-none animate-fade-in-left" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                    KNOWLEDGE<br/><span class="text-primary">BASELINE</span>_
                </h1>
            </div>
            <div class="max-w-xs md:text-right">
                <p class="text-slate-400 text-xs md:text-sm leading-relaxed animate-fade-in-up" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                    Formal education and structured learning that forms the technical foundation for all engineering practice.
                </p>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-2 animate-fade-in-up" style="animation-delay: 800ms; animation-fill-mode: both; opacity: 0;">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
            <span class="font-label text-[10px] tracking-[0.3em] uppercase text-slate-500">@educations.Count Institutions</span>
        </div>
    </header>

    <!-- Education Auto-Scroll Track (Left to Right) -->
    <div class="scroll-track-reverse">
        <div class="scroll-track-inner-reverse py-4">
            @* First set *@
            @for (int i = 0; i < educations.Count; i++)
            {
                var edu = educations[i];
                <EducationCard Education="@edu" Index="@i" />
            }
            @* Duplicated set for seamless loop *@
            @for (int i = 0; i < educations.Count; i++)
            {
                var edu = educations[i];
                <EducationCard Education="@edu" Index="@(educations.Count + i)" />
            }
        </div>
    </div>

    <!-- Footer Note -->
    <div class="mt-20 md:mt-24 max-w-5xl mx-auto border-t border-outline-variant/10 pt-8">
        <p class="font-body text-slate-600 text-xs leading-relaxed">
            Continuous learning extends beyond formal education. Additional certifications, self-directed study, and hands-on engineering practice compound into the complete technical capability reflected across this portfolio.
        </p>
    </div>
</section>

@code {
    private readonly List<Education> educations = EducationData.Educations;
}
