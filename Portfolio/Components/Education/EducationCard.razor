@using Portfolio.Models

<div class="group relative bg-gradient-to-br from-surface-container-high via-surface-container to-surface-container-low border border-outline-variant/20 p-6 md:p-8 transition-all duration-500 hover:border-primary/40 hover:shadow-glow-cyan hover:scale-[1.02] animate-fade-in-up overflow-hidden" style="animation-delay: @(Index * 150)ms; animation-fill-mode: both; opacity: 0;">
    <!-- Animated Gradient Sweep on Hover -->
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-primary/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out pointer-events-none"></div>

    <!-- Top Glow Line -->
    <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-primary/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

    <!-- Corner Accent -->
    <div class="absolute top-0 right-0 w-0 h-0 border-t-[3px] border-r-[3px] border-transparent group-hover:border-primary/50 transition-all duration-500"></div>
    
    <!-- Year Badge -->
    <div class="inline-flex items-center gap-2 mb-4 relative z-10">
        <span class="font-label text-[10px] tracking-widest text-primary bg-primary/10 border border-primary/20 px-3 py-1">@Education.Year</span>
        <div class="flex-1 h-[1px] bg-gradient-to-r from-primary/20 to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="space-y-3 relative z-10">
        <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary/80 text-xl mt-0.5 group-hover:animate-pulse">school</span>
            <h3 class="font-headline text-lg md:text-xl font-bold uppercase tracking-tight text-white leading-tight group-hover:text-gradient">@Education.Title</h3>
        </div>
        <p class="font-body text-xs md:text-sm text-slate-400 pl-9">@Education.Issuer</p>
    </div>

    <!-- Bottom Decorative Dots -->
    <div class="absolute bottom-3 right-3 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
        <span class="w-1 h-1 rounded-full bg-primary/60"></span>
        <span class="w-1 h-1 rounded-full bg-primary/40"></span>
        <span class="w-1 h-1 rounded-full bg-primary/20"></span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public required Education Education { get; set; }
    [Parameter, EditorRequired] public required int Index { get; set; }
}
