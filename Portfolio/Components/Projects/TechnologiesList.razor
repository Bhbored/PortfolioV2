<!-- Technologies Used Card -->
<div class="relative overflow-hidden rounded-2xl bg-gradient-card p-7 border border-white/10 card-hover-lift group">
    <!-- Top accent glow line -->
    <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-cyan-500 via-cyan-400 to-transparent"></div>
    
    <!-- Subtle corner glow -->
    <div class="absolute -top-20 -right-20 w-40 h-40 bg-cyan-500/5 rounded-full blur-3xl group-hover:bg-cyan-500/10 transition-colors duration-500"></div>
    
    <!-- Header -->
    <div class="relative mb-6 pb-4 border-b border-white/5">
        <h3 class="text-xl font-bold uppercase tracking-wider mb-1.5">
            <span class="bg-gradient-to-r from-cyan-300 via-cyan-400 to-cyan-500 bg-clip-text text-transparent drop-shadow-[0_0_20px_rgba(34,211,238,0.3)]">
                Technologies Used
            </span>
        </h3>
        <p class="text-[11px] uppercase tracking-[0.15em] text-zinc-500 font-medium">The tools and frameworks powering this project</p>
    </div>

    <!-- Tech Badges -->
    <div class="relative flex flex-wrap gap-2.5">
        @foreach (var tech in Technologies)
        {
            <span class="inline-flex items-center px-3.5 py-1.5 rounded-full text-xs font-semibold tracking-wide transition-all duration-300 cursor-default border tech-badge-cyan">
                @tech
            </span>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public required List<string> Technologies { get; set; }
}
