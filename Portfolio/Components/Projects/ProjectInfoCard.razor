<!-- Project Information Card -->
<div class="relative overflow-hidden rounded-2xl bg-gradient-card p-7 border border-white/10 card-hover-lift group h-[360px] md:h-[340px]">
    <!-- Top accent glow line -->
    <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-orange-500 via-orange-400 to-transparent"></div>
    
    <!-- Subtle corner glow -->
    <div class="absolute -top-20 -right-20 w-40 h-40 bg-orange-500/5 rounded-full blur-3xl group-hover:bg-orange-500/10 transition-colors duration-500"></div>
    
    <!-- Header -->
    <div class="relative mb-6 pb-4 border-b border-white/5">
        <h3 class="text-xl font-bold uppercase tracking-wider mb-1.5">
            <span class="bg-gradient-to-r from-orange-300 via-orange-400 to-orange-500 bg-clip-text text-transparent drop-shadow-[0_0_20px_rgba(251,146,60,0.3)]">
                Project Information
            </span>
        </h3>
        <p class="text-[11px] uppercase tracking-[0.15em] text-zinc-500 font-medium">Essential details about this project</p>
    </div>

    <!-- Info Items -->
    <div class="relative flex flex-col gap-0">
        <!-- Category -->
        <div class="info-row-item">
            <p class="info-label-orange">Category</p>
            <p class="info-value-white">@ProjectCategoryHelper.GetCategoryDisplayName(Category)</p>
        </div>

        <!-- Repository -->
        @if (!string.IsNullOrEmpty(RepositoryUrl))
        {
            <div class="info-row-item">
                <p class="info-label-orange">Repository</p>
                <a href="@RepositoryUrl" target="_blank" rel="noopener noreferrer" class="info-link-orange">
                    View on GitHub
                    <svg class="w-3.5 h-3.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                </a>
            </div>
        }

        <!-- Tech Stack Count -->
        <div class="info-row-item">
            <p class="info-label-orange">Tech Stack</p>
            <p class="info-value-white">@TechCount</p>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public required ProjectCategory Category { get; set; }
    [Parameter] public string? RepositoryUrl { get; set; }
    [Parameter, EditorRequired] public required int TechnologyCount { get; set; }

    private string TechCount => $"{TechnologyCount} Technologies";
}
