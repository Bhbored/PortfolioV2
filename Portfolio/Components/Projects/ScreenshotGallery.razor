@using Portfolio.Models.Enums
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<!-- Screenshot Gallery Component -->
<div class="screenshot-gallery w-full" @ref="galleryRef">
    <!-- Navigation Arrows -->
    <button type="button" class="hidden md:flex absolute left-[-1.5rem] top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-surface-container-high/90 backdrop-blur-sm border border-white/20 items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300"
            @onclick="ScrollLeft">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
    </button>
    <button type="button" class="hidden md:flex absolute right-[-1.5rem] top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-surface-container-high/90 backdrop-blur-sm border border-white/20 items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300"
            @onclick="ScrollRight">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
    </button>

    <!-- Mobile Navigation Arrows -->
    <button type="button" class="md:hidden absolute left-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-surface-container-high/90 backdrop-blur-sm border border-white/20 flex items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300"
            @onclick="ScrollLeft">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
    </button>
    <button type="button" class="md:hidden absolute right-2 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-surface-container-high/90 backdrop-blur-sm border border-white/20 flex items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300"
            @onclick="ScrollRight">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
    </button>

    <!-- Gallery Container -->
    <div class="screenshot-container">
        @for (int i = 0; i < Screenshots.Count; i++)
        {
            var screenshot = Screenshots[i];
            var index = i;
            var altText = $"Screenshot {index + 1}";
            <div class="screenshot-item flex-shrink-0 cursor-pointer"
                 @onclick="() => OpenPreview(index)">
                <ScreenshotItem Src="@screenshot" Alt="@altText" Category="@ProjectCategory" />
                <!-- Hover Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center pointer-events-none">
                    <div class="w-16 h-16 rounded-full bg-primary/20 backdrop-blur-sm border border-primary/50 flex items-center justify-center">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                        </svg>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Image Preview Modal -->
    @if (isPreviewOpen && SelectedImageIndex.HasValue)
    {
        <div class="fixed inset-0 z-50 bg-black/90 backdrop-blur-sm flex items-center justify-center p-3 md:p-4 animate-fade-in" @onclick="ClosePreview">
            <div class="relative @(IsMobileCategory() ? "max-w-xs md:max-w-sm" : "max-w-7xl") w-full flex flex-col items-center justify-center" @onclick:stopPropagation="true">
                <!-- Close Button -->
                <button type="button" class="absolute -top-2 -right-2 md:-top-3 md:-right-3 z-50 w-10 h-10 md:w-11 md:h-11 rounded-full bg-surface-container-high border border-white/20 flex items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300" @onclick="ClosePreview">
                    <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>

                <!-- Image -->
                <img src="@Screenshots[SelectedImageIndex.Value]" alt="Preview" class="@(IsMobileCategory() ? "max-h-[65vh] md:max-h-[75vh] w-auto" : "w-full h-auto max-h-[85vh]") object-contain rounded-lg" />

                <!-- Navigation Arrows -->
                @if (Screenshots.Count > 1)
                {
                    <button type="button" class="absolute -left-4 md:-left-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 rounded-full bg-surface-container-high/80 backdrop-blur-sm border border-white/20 flex items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300" @onclick="PreviousImage">
                        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                    <button type="button" class="absolute -right-4 md:-right-6 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 rounded-full bg-surface-container-high/80 backdrop-blur-sm border border-white/20 flex items-center justify-center text-white hover:bg-primary/20 hover:border-primary/50 transition-all duration-300" @onclick="NextImage">
                        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>

                    <!-- Image Counter -->
                    <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 px-4 py-2 bg-surface-container-high/80 backdrop-blur-sm rounded-full border border-white/20 text-white font-label text-sm whitespace-nowrap">
                        @(SelectedImageIndex.Value + 1) / @Screenshots.Count
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required List<string> Screenshots { get; set; }
    [Parameter, EditorRequired] public ProjectCategory ProjectCategory { get; set; } = ProjectCategory.WebApplication;

    private bool isPreviewOpen = false;
    private int? SelectedImageIndex = null;
    private ElementReference galleryRef;

    private bool IsMobileCategory()
    {
        return ProjectCategory switch
        {
            ProjectCategory.MobileApp or
            ProjectCategory.iOSApp or
            ProjectCategory.AndroidApp or
            ProjectCategory.CrossPlatformMobile or
            ProjectCategory.MobileGame
                => true,
            _ => false
        };
    }

    private void OpenPreview(int index)
    {
        SelectedImageIndex = index;
        isPreviewOpen = true;
    }

    private void ClosePreview()
    {
        isPreviewOpen = false;
        SelectedImageIndex = null;
    }

    private void NextImage()
    {
        if (SelectedImageIndex.HasValue && Screenshots.Count > 0)
        {
            SelectedImageIndex = (SelectedImageIndex.Value + 1) % Screenshots.Count;
        }
    }

    private void PreviousImage()
    {
        if (SelectedImageIndex.HasValue && Screenshots.Count > 0)
        {
            SelectedImageIndex = (SelectedImageIndex.Value - 1 + Screenshots.Count) % Screenshots.Count;
        }
    }

    private async Task ScrollLeft()
    {
        await JS.InvokeVoidAsync("scrollGallery", galleryRef, -1);
    }

    private async Task ScrollRight()
    {
        await JS.InvokeVoidAsync("scrollGallery", galleryRef, 1);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (isPreviewOpen)
        {
            await JS.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
        }
        else if (!firstRender)
        {
            await JS.InvokeVoidAsync("eval", "document.body.style.overflow = ''");
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.body.style.overflow = ''");
        }
        catch
        {
        }
    }
}
