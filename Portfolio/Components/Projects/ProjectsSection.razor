@using Portfolio.Models
@using Portfolio.Contracts
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject IModelToJsonService ModelToJsonService

<section id="projects" class="pt-16 md:pt-24 pb-16 md:pb-24 px-6 md:px-8 min-h-screen mesh-gradient relative overflow-hidden">
    <!-- Hero Section Title -->
    <header class="mb-16 md:mb-24 relative">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="inline-block relative">
                <span class="absolute -top-4 md:-top-6 left-0 font-label text-[8px] md:text-[10px] tracking-[0.4em] text-primary/40 uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">// DOCUMENTATION_MODULE_04</span>
                <h1 class="font-headline text-[48px] md:text-[80px] lg:text-[96px] font-black tracking-tighter uppercase leading-none animate-fade-in-left" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                    Featured<br /><span class="text-primary">Projects</span>
                </h1>
            </div>
            <div class="max-w-xs md:text-right border-r-2 md:border-r-0 md:border-l-2 border-primary/20 md:pl-6 pr-4 md:pr-0">
                <p class="text-slate-400 text-xs md:text-sm leading-relaxed animate-fade-in-up" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                    Click on any project to see detailed features, technologies, and screenshots.
                </p>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-2 animate-fade-in-up" style="animation-delay: 800ms; animation-fill-mode: both; opacity: 0;">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
            <span class="font-label text-[10px] tracking-[0.3em] uppercase text-slate-500">@projects.Count Projects Archived</span>
        </div>
    </header>

    <!-- Projects Horizontal Scroll Container -->
    <div class="max-w-screen-2xl mx-auto relative">
        <div class="projects-viewport overflow-x-auto md:overflow-hidden"
             style="scrollbar-width: none; -ms-overflow-style: none;">
            <div class="projects-track" id="projects-track">
                @for (int i = 0; i < projects.Count; i++)
                {
                    var project = projects[i];
                    <div class="project-slide">
                        <ProjectCard Project="project" Index="@i" />
                    </div>
                }
            </div>
        </div>

        <!-- Navigation Buttons -->
        <div class="flex justify-between items-center mt-12 hidden md:flex">
            <button @onclick="PreviousPage"
                    disabled="@(currentIndex == 0)"
                    class="px-6 py-3 bg-surface-container-high border border-outline-variant/30 text-primary font-label text-xs tracking-widest uppercase hover:border-primary/50 hover:shadow-glow-cyan transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed">
                <span class="material-symbols-outlined text-sm mr-2">arrow_back</span>
                Previous
            </button>

            <span class="text-on-surface-variant font-label text-xs tracking-widest">
                @($"{currentIndex / PageSize + 1} / {(projects.Count + PageSize - 1) / PageSize}")
            </span>

            <button @onclick="NextPage"
                    disabled="@(currentIndex + PageSize >= projects.Count)"
                    class="px-6 py-3 bg-surface-container-high border border-outline-variant/30 text-primary font-label text-xs tracking-widest uppercase hover:border-primary/50 hover:shadow-glow-cyan transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed">
                Next
                <span class="material-symbols-outlined text-sm ml-2">arrow_forward</span>
            </button>
        </div>
    </div>
</section>

@code {
    private List<Project> projects = [];
    private int currentIndex = 0;
    private const int PageSize = 3;

    protected override async Task OnInitializedAsync()
    {
        projects = await ModelToJsonService.GetProjectsAsync();
    }

    private async Task NextPage()
    {
        if (currentIndex + PageSize < projects.Count)
        {
            currentIndex += PageSize;
            await JS.InvokeVoidAsync("slideProjectsTrack", currentIndex);
        }
    }

    private async Task PreviousPage()
    {
        if (currentIndex - PageSize >= 0)
        {
            currentIndex -= PageSize;
            await JS.InvokeVoidAsync("slideProjectsTrack", currentIndex);
        }
    }
}
