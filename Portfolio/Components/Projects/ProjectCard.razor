@using Portfolio.Models

<div class="flex flex-col gap-6 animate-fade-in-up" style="animation-delay: @(Index * 150 + 600)ms; animation-fill-mode: both; opacity: 0;">
    <!-- Stage Label -->
    <div class="flex items-center gap-3 mb-2">
        <span class="text-xs font-label tracking-[0.1em] text-primary bg-primary/10 border border-primary/20 px-3 py-1 uppercase">Stage @((Index + 1).ToString("D2"))</span>
    </div>

    <!-- Card Content -->
    <div class="group relative aspect-video bg-surface-container-low overflow-hidden border border-outline-variant/10 transition-all duration-500 hover:border-primary/40 hover:shadow-glow-cyan hover:scale-[1.02]">
        <!-- Animated Gradient Sweep on Hover -->
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-primary/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out pointer-events-none z-10"></div>

        <!-- Top Glow Line -->
        <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-primary/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20"></div>

        <!-- Project Image -->
        <div class="absolute inset-0 scale-[0.95] transition-transform duration-700 group-hover:scale-100">
            <img src="@project.ImageUrl" alt="@project.Title" class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-60 transition-all duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0f] via-transparent to-transparent"></div>
        </div>

        <!-- Interactive Cursor Overlay -->
        <div class="absolute top-[40%] left-[60%] -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20">
            <div class="w-20 h-20 md:w-24 md:h-24 rounded-full border border-primary-container flex items-center justify-center backdrop-blur-sm bg-primary-container/5 shadow-[0_0_30px_rgba(0,240,255,0.2)]">
                <span class="text-primary font-label text-[10px] md:text-xs font-black tracking-[0.2em]">VIEW</span>
            </div>
        </div>

        <!-- Interaction Labels -->
        <div class="absolute top-4 left-4 md:top-6 md:left-6 z-20">
            <div class="text-[10px] font-label text-primary tracking-widest uppercase">Target: @project.Title</div>
        </div>

        <!-- Bottom Decorative Dots -->
        <div class="absolute bottom-3 right-3 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20">
            <span class="w-1 h-1 rounded-full bg-primary/60"></span>
            <span class="w-1 h-1 rounded-full bg-primary/40"></span>
            <span class="w-1 h-1 rounded-full bg-primary/20"></span>
        </div>
    </div>

    <!-- Project Info -->
    <div>
        <h4 class="font-headline font-bold text-sm md:text-base lg:text-lg xl:text-xl mb-2 text-white group-hover:text-gradient transition-all duration-500">@project.Title</h4>
        <p class="text-xs sm:text-sm md:text-base text-on-surface-variant/80 font-body mb-4">@project.Description</p>

        <!-- Technologies -->
        <div class="flex flex-wrap gap-2">
            @foreach (var tech in project.Technologies)
            {
                <span class="text-[10px] font-label tracking-widest uppercase text-primary bg-primary/10 border border-primary/20 px-2 py-1">@tech</span>
            }
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4 mt-4">
            <a href="@project.GithubUrl" class="flex items-center gap-2 text-xs font-label tracking-widest uppercase text-on-surface-variant hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-sm">code</span>
                Code
            </a>
            <a href="@project.LiveUrl" class="flex items-center gap-2 text-xs font-label tracking-widest uppercase text-on-surface-variant hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-sm">launch</span>
                Live Demo
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public required Project Project { get; set; }
    [Parameter, EditorRequired] public required int Index { get; set; }

    private Project project => Project;
}
