@using Portfolio.Models
@using Portfolio.Contracts
@using Portfolio.Helpers
@inject ISkillService SkillService

<section id="skills" class="min-h-screen pt-16 md:pt-20 pb-24 md:pb-32 px-6 max-w-screen-2xl mx-auto overflow-x-hidden mesh-gradient">
    <!-- Section Header -->
    <header class="mb-16 md:mb-24 relative">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="inline-block relative">
                <span class="absolute -top-4 md:-top-6 left-0 font-label text-[8px] md:text-[10px] tracking-[0.4em] text-primary/40 uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">// SYSTEM_CAPABILITIES_LOADED</span>
                <h1 class="font-headline text-[48px] md:text-[80px] lg:text-[96px] font-black tracking-tighter uppercase leading-none animate-fade-in-left" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                    TECH<br /><span class="text-primary">ARSENAL</span>_
                </h1>
            </div>
            <div class="max-w-xs md:text-right border-r-2 md:border-r-0 md:border-l-2 border-primary/20 md:pl-6 pr-4 md:pr-0">
                <p class="text-slate-400 text-xs md:text-sm leading-relaxed animate-fade-in-up" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                    A multi-layered technical stack engineered for high-performance distributed systems, immersive interfaces, and cognitive computational tools.
                </p>
            </div>
        </div>
        <div class="mt-4 flex items-center gap-2 animate-fade-in-up" style="animation-delay: 800ms; animation-fill-mode: both; opacity: 0;">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
            <span class="font-label text-[10px] tracking-[0.3em] uppercase text-slate-500">@categories.Count Skill Categories</span>
        </div>
    </header>

    <!-- Skills Categories with Auto-Scroll -->
    @if (categories != null && categories.Any())
    {
        <div class="space-y-16 md:space-y-24">
            @for (int i = 0; i < categories.Count; i++)
            {
                var category = categories[i];
                var isEven = i % 2 == 0;
                var categorySkills = skills.Where(s => s.SkillCategoryID == category.Id).ToList();

                <div class="skill-category animate-fade-in-up" style="animation-delay: @(800 + i * 150)ms; animation-fill-mode: both; opacity: 0;">
                    <!-- Category Header -->
                    <div class="flex items-center gap-3 md:gap-4 mb-6 md:mb-8">
                        <span class="font-label text-xs bg-surface-container-high px-2 py-1 text-primary">0@(i + 1)</span>
                        <h3 class="font-headline font-bold tracking-tight text-lg md:text-xl uppercase">@category.Category</h3>
                    </div>

                    <!-- Auto-Scroll Track (alternating direction) -->
                    @if (isEven)
                    {
                        <div class="skills-scroll-track">
                            <div class="skills-scroll-track-inner">
                                @foreach (var skill in categorySkills)
                                {
                                    var icon = MaterialIconHelper.ToIconString(skill.Icon);
                                    <div class="skill-card-wrapper">
                                        <SkillCard Skill="skill" Icon="@icon" Index="@(i * 10 + skills.IndexOf(skill))" />
                                    </div>
                                }
                                @foreach (var skill in categorySkills)
                                {
                                    var icon = MaterialIconHelper.ToIconString(skill.Icon);
                                    <div class="skill-card-wrapper">
                                        <SkillCard Skill="skill" Icon="@icon" Index="@(i * 10 + skills.IndexOf(skill))" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="skills-scroll-track-reverse">
                            <div class="skills-scroll-track-inner-reverse">
                                @foreach (var skill in categorySkills)
                                {
                                    var icon = MaterialIconHelper.ToIconString(skill.Icon);
                                    <div class="skill-card-wrapper">
                                        <SkillCard Skill="skill" Icon="@icon" Index="@(i * 10 + skills.IndexOf(skill))" />
                                    </div>
                                }
                                @foreach (var skill in categorySkills)
                                {
                                    var icon = MaterialIconHelper.ToIconString(skill.Icon);
                                    <div class="skill-card-wrapper">
                                        <SkillCard Skill="skill" Icon="@icon" Index="@(i * 10 + skills.IndexOf(skill))" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</section>

@code {
    private List<SkillCategory>? categories;
    private List<Skill>? skills;

    protected override async Task OnInitializedAsync()
    {
        categories = await SkillService.GetALLSkillCategoriesAsync();
        skills = await SkillService.GetAllSkillsAsync();
    }
}
