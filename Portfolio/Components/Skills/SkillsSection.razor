@using Portfolio.Models
@using Portfolio.Mockdata

<section id="skills" class="min-h-screen pt-24 md:pt-32 pb-40 px-6 max-w-screen-2xl mx-auto overflow-x-hidden mesh-gradient">
    <!-- Section Header -->
    <header class="mb-16 md:mb-32 relative">
        <div class="inline-block relative">
            <span class="absolute -top-4 md:-top-6 left-0 font-label text-[8px] md:text-[10px] tracking-[0.4em] text-primary/40 uppercase animate-fade-in-up" style="animation-delay: 200ms; animation-fill-mode: both; opacity: 0;">// SYSTEM_CAPABILITIES_LOADED</span>
            <h1 class="font-headline text-[48px] md:text-[80px] lg:text-[96px] font-black tracking-tighter uppercase leading-none animate-fade-in-left" style="animation-delay: 400ms; animation-fill-mode: both; opacity: 0;">
                TECH<br/>ARSENAL
            </h1>
        </div>
        <div class="mt-6 md:mt-8 max-w-xl border-l-2 border-primary/20 pl-4 md:pl-6">
            <p class="text-on-surface-variant font-body text-sm md:text-lg leading-relaxed animate-fade-in-up" style="animation-delay: 600ms; animation-fill-mode: both; opacity: 0;">
                A multi-layered technical stack engineered for high-performance distributed systems, immersive interfaces, and cognitive computational tools.
            </p>
        </div>
    </header>

    <!-- Asymmetric Skills Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 items-start">
        @for (int i = 0; i < categories.Count; i++)
        {
            var category = categories[i];
            <div class="flex flex-col space-y-6 md:space-y-8 animate-fade-in-up" style="animation-delay: @(800 + i * 150)ms; animation-fill-mode: both; opacity: 0;">
                <div class="flex items-center gap-3 md:gap-4 mb-4">
                    <span class="font-label text-xs bg-surface-container-high px-2 py-1 text-primary">0@(i + 1)</span>
                    <h3 class="font-headline font-bold tracking-tight text-lg md:text-xl uppercase">@category.Category</h3>
                </div>

                @for (int j = 0; j < category.Skills.Count; j++)
                {
                    var skill = category.Skills[j];
                    var icon = GetIconForSkill(skill.Title);

                    <SkillCard Skill="skill" Icon="@icon" Index="@(i * 10 + j)" />
                }
            </div>
        }
    </div>
</section>

@code {
    private readonly List<SkillCategory> categories = SkillData.Categories;

    private static string GetIconForSkill(string title)
    {
        var lower = title.ToLowerInvariant();

        if (lower.Contains("c#") || lower.Contains(".net") || lower.Contains("asp"))
            return "terminal";

        if (lower.Contains("typescript") || lower.Contains("javascript"))
            return "code";

        if (lower.Contains("flutter") || lower.Contains("dart"))
            return "devices";

        if (lower.Contains("maui"))
            return "layers";

        if (lower.Contains("react") || lower.Contains("next"))
            return "auto_awesome_motion";

        if (lower.Contains("blazor") || lower.Contains("wasm"))
            return "javascript";

        if (lower.Contains("sql") || lower.Contains("postgres"))
            return "storage";

        if (lower.Contains("node") || lower.Contains("express"))
            return "memory";

        if (lower.Contains("ai") || lower.Contains("llm"))
            return "psychology";

        return "code";
    }
}
