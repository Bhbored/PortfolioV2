@page "/project/{ProjectId}"
@inject NavigationManager Navigation
@inject IModelToJsonService ModelToJsonService
@layout EmptyLayout
<!-- Project Details Page -->
<div class="relative w-full min-h-screen bg-background">
    <!-- Hero Section with Full-Width Image -->
    @if (project != null)
    {
        <!-- Project Hero Image -->
        @if (!string.IsNullOrEmpty(project.ImageUrl))
        {
            <div class="relative w-full h-[50vh] md:h-[60vh] lg:h-[70vh] overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent z-10"></div>
                <img src="@project.ImageUrl" alt="@project.Title" class="w-full h-full object-cover" />

                <!-- Back Button Overlay -->
                <button type="button" class="absolute top-6 left-6 md:top-8 md:left-12 z-20 inline-flex items-center gap-2 px-4 py-2 bg-surface-container-high/80 backdrop-blur-sm border border-white/10 rounded-full text-on-surface-variant hover:text-primary hover:border-primary/50 transition-all duration-300 group" @onclick="GoBack">
                    <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    <span class="font-label text-sm uppercase tracking-widest">Back</span>
                </button>
            </div>
        }

        <!-- Project Header Section -->
        <div class="relative z-20 -mt-24 md:-mt-32 px-6 md:px-12">
            <div class="max-w-screen-xl mx-auto">
                @if (!string.IsNullOrEmpty(project.ImageUrl))
                {
                    <button type="button" class="hidden md:inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors mb-6 group" @onclick="GoBack">
                        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        <span class="font-label text-sm uppercase tracking-widest">Back to Projects</span>
                    </button>
                }

                <!-- Project Title & Description -->
                <div class="mb-8 md:mb-12">
                    <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-[0.9] tracking-tight mb-4 md:mb-6">
                        @project.Title
                    </h1>
                    <p class="font-body text-lg md:text-xl lg:text-2xl text-on-surface-variant/80 leading-relaxed max-w-3xl">
                        @project.Description
                    </p>
                </div>

                <!-- Quick Stats Row -->
                <div class="flex flex-wrap gap-4 md:gap-6 pb-8 border-b border-white/10">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="font-label text-xs uppercase tracking-widest text-primary">Category</p>
                            <p class="font-body text-sm text-on-surface-variant">@ProjectCategoryHelper.GetCategoryDisplayName(project.ProjectCategory)</p>
                        </div>
                    </div>

                    @if (project.Technologies != null && project.Technologies.Any())
                    {
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="font-label text-xs uppercase tracking-widest text-primary">Tech Stack</p>
                                <p class="font-body text-sm text-on-surface-variant">@project.Technologies.Count Technologies</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(project.GithubUrl))
                    {
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="font-label text-xs uppercase tracking-widest text-primary">Repository</p>
                                <a href="@project.GithubUrl" target="_blank" rel="noopener noreferrer" class="font-body text-sm text-on-surface-variant hover:text-primary transition-colors hover:underline">View on GitHub</a>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(project.LiveUrl))
                    {
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="font-label text-xs uppercase tracking-widest text-primary">Live Demo</p>
                                <a href="@project.LiveUrl" target="_blank" rel="noopener noreferrer" class="font-body text-sm text-on-surface-variant hover:text-primary transition-colors hover:underline">Visit Site</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="relative z-20 px-6 md:px-12 py-12 md:py-16">
            <div class="max-w-screen-xl mx-auto">
                <!-- Screenshots Gallery Section -->
                @if (project.Screenshots != null && project.Screenshots.Any())
                {
                    <div class="mb-16 md:mb-24">
                        <h2 class="section-title">Project Screenshots</h2>
                        <ScreenshotGallery Screenshots="@project.Screenshots" />
                    </div>
                }

                <!-- Three Column Layout: Technologies & Key Features (Left 2/3) | Project Info (Right 1/3) -->
                <div class="content-grid">
                    <!-- Left Column: Technologies + Key Features -->
                    <div class="left-column">
                        <!-- Technologies Used -->
                        @if (project.Technologies != null && project.Technologies.Any())
                        {
                            <TechnologiesList Technologies="@project.Technologies" />
                        }

                        <!-- Key Features -->
                        @if (project.KeyFeatures != null && project.KeyFeatures.Any())
                        {
                            <KeyFeaturesList Features="@project.KeyFeatures" />
                        }
                    </div>

                    <!-- Right Column: Project Information -->
                    <div class="right-column">
                        <ProjectInfoCard Category="@project.ProjectCategory"
                                         RepositoryUrl="@(project.GithubUrl)"
                                         TechnologyCount="@(project.Technologies?.Count ?? 0)" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? ProjectId { get; set; }
    private string projectTitle = string.Empty;
    private Project? project;
    private List<Project> allProjects = [];

    protected override async Task OnInitializedAsync()
    {
        allProjects = await ModelToJsonService.GetProjectsAsync();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(ProjectId))
        {
            if (int.TryParse(ProjectId, out int id) && id >= 0 && id < allProjects.Count)
            {
                project = allProjects[id];
                projectTitle = project.Title;
            }
            else
            {
                project = allProjects.FirstOrDefault(p =>
                    p.Title.ToLowerInvariant().Replace(" ", "-") == ProjectId?.ToLowerInvariant());
            }
        }

        if (project == null)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
}
