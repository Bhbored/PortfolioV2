@page "/"
@using Portfolio.Mockdata
@using Portfolio.Components.Landing
@using Portfolio.Components.Skills
@using Portfolio.Components.Projects
@using Portfolio.Components.Experience
@using Portfolio.Components.Certificates
@using Portfolio.Components.Education

<PageTitle>Home | BH DEVELOPER NOIR</PageTitle>

<div class="home-container">
    <!-- Hero Section -->
    <HeroSection Info="@PersonalInfo" />

    <!-- Skills Section -->
    <SkillsSection />

    <!-- Projects Section -->
    <ProjectsSection />

    <!-- Experience Section -->
    <ExperienceSection />

    <!-- Certificates Section -->
    <CertificatesSection />

    <!-- Education Section -->
    <EducationSection />

    <!-- Contact Section -->
    <section id="contact" class="min-h-screen flex items-center justify-center mesh-gradient px-6">
        <div class="text-center">
            <h2 class="font-headline text-[32px] md:text-[48px] lg:text-[64px] font-bold uppercase mb-4">Contact</h2>
            <p class="font-body text-white/60 text-sm md:text-lg">Contact section coming soon...</p>
        </div>
    </section>
</div>

@code {
    private PersonalInfo PersonalInfo = new();
    protected override void OnInitialized()
    {
        base.OnInitialized();
        PersonalInfo = PersonalInfoData.GetDeveloper();
    }
}
