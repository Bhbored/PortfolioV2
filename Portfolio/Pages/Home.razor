@page "/"
@using Portfolio.Components.Landing
@using Portfolio.Components.Skills
@using Portfolio.Components.Projects
@using Portfolio.Components.Experience
@using Portfolio.Components.Certificates
@using Portfolio.Components.Education
@using Portfolio.Components.Contact
@using Portfolio.Models
@using Portfolio.Contracts
@inject IModelToJsonService ModelToJsonService
@layout MainLayout

<div class="home-container">
    <!-- Hero Section -->
    <HeroSection Info="@PersonalInfo" />

    <!-- Skills Section -->
    <SkillsSection />

    <!-- Projects Section -->
    <ProjectsSection />

    <!-- Experience Section -->
    <ExperienceSection />

    <!-- Certificates Section -->
    <CertificatesSection />

    <!-- Education Section -->
    <EducationSection />

    <!-- Contact Section -->
    <ContactSection Info="@PersonalInfo" />
</div>

@code {
    private PersonalInfo PersonalInfo = new();

    protected override async Task OnInitializedAsync()
    {
        PersonalInfo = await ModelToJsonService.GetPersonalInfoAsync();
    }
}
